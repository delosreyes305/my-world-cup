VITE_FOOTBALL_API_KEY=YOUR_API_FOOTBALL_KEY_HERE
VITE_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

VITE_NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE
VITE_NEWS_BASE_URL=https://newsapi.org/v2

# Dev only — the Vite middleware in vite.config.js reads this to proxy /api/claude locally.
# In production (Vercel) set ANTHROPIC_API_KEY (no VITE_ prefix) in the dashboard instead.
VITE_ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
