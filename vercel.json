{
    "builds": [{
        "src": "package.json",
        "use": "@vercel/static-build"
    }],
    "rewrites": [
        {
            "source": "/api/football/:path*",
            "destination": "https://v3.football.api-sports.io/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
